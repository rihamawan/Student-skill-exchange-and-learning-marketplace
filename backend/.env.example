# Server port (default: 5000)
PORT=5000

# MySQL (Member 3 — DB layer)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=skill_exchange_db

# JWT (Member 2 — Auth)
# Secret used to sign and verify tokens. Use a long random string in production.
JWT_SECRET=your-super-secret-key-change-in-production
# How long the token is valid. Examples: 7d, 24h, 60m
JWT_EXPIRES_IN=7d
